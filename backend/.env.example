# Gemini API Key & Model (obtain from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# MongoDB Atlas Connection URI (obtain from https://www.mongodb.com/cloud/atlas)
MONGO_URI=mongodb+srv://username:password@cluster0.xxx.mongodb.net/smartrupee?retryWrites=true&w=majority

# Application Environment (development / production)
ENV=development

# Server Port (default 8000 for local, Azure Web App injects PORT automatically)
PORT=8000
